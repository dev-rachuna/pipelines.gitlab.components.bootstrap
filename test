#!/bin/bash

set -euo pipefail

echo "🔄 Konwersja .yml → .sh (klucze kończące się na .sh)"

if ! command -v yq >/dev/null 2>&1; then
  echo "❌ Brak wymaganego polecenia 'yq'" >&2
  exit 1
fi

echo "yq: $(yq --version)"

shopt -s globstar nullglob
yaml_files=(./**/*.yml)

if (( ${#yaml_files[@]} == 0 )); then
  echo "❌ Nie znaleziono plików .yml" >&2
  exit 1
fi

for file_yml in "${yaml_files[@]}"; do
  echo "📄 Przetwarzanie: $file_yml"
  dir="$(dirname "$file_yml")"
  keys="$(yq -r 'keys[] | select(endswith(".sh"))' "$file_yml")"

  while IFS= read -r key; do
      [ -z "$key" ] && continue
      key_noext="${key#.}"
      key_noext="${key_noext%.sh}"
      basename_part="${key_noext##*.}"
      output="$dir/${basename_part}.sh"

      echo "$file_yml [$key] ==> $output"
      # shellcheck disable=SC2016
      yq -r --arg k "$key" '.[$k] | .[] | select(type == "string")' "$file_yml" > "$output"
  done <<< "$keys"
done
